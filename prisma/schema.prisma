datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id        String   @id @default(uuid())
  name      String
  brand     String?
  prices    Price[]
  createdAt DateTime @default(now())
}

model Price {
  id        String   @id @default(uuid())
  amount    Float
  store     String
  zipCode   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  createdAt DateTime @default(now())
}
